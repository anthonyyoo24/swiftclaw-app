{
  "name": "swiftclaw",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:app\"",
    "dev:web": "next dev",
    "dev:app": "wait-on http://localhost:3000 && cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "next build && electron-vite build && electron-builder",
    "build:web": "next build",
    "build:app": "electron-vite build && electron-builder",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "build": {
    "appId": "com.anthonyyoo.swiftclaw",
    "productName": "SwiftClaw",
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "."
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "buildResources/entitlements.mac.plist",
      "entitlementsInherit": "buildResources/entitlements.mac.plist",
      "notarize": true,
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "anthonyyoo24",
      "repo": "swiftclaw-app"
    }
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.91",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@grammyjs/types": "^3.25.0",
    "@hookform/resolvers": "^5.2.2",
    "@iconify/react": "^6.0.2",
    "@lobehub/icons": "^5.0.1",
    "@lobehub/ui": "^5.6.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "debug": "^4.4.3",
    "electron-log": "^5.4.3",
    "grammy": "^1.41.1",
    "lucide-react": "^0.575.0",
    "next": "^16.2.2",
    "next-themes": "^0.4.6",
    "openclaw": "^2026.4.27",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/debug": "^4.1.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.47",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.2",
    "jsdom": "^29.0.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
